local player = game.Players.LocalPlayer

-- ===== GUI =====
local gui = Instance.new("ScreenGui")
gui.Name = "CarryGUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- ไอคอน
local icon = Instance.new("TextButton")
icon.Size = UDim2.new(0,50,0,50)
icon.Position = UDim2.new(0,20,0,200)
icon.Text = "🧍"
icon.BackgroundColor3 = Color3.fromRGB(40,40,40)
icon.Parent = gui

icon.Active = true
icon.Draggable = true

-- เมนู
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,200,0,100)
frame.Position = UDim2.new(0,80,0,200)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Visible = false
frame.Parent = gui

frame.Active = true
frame.Draggable = true

-- ปุ่มอุ้ม
local btn = Instance.new("TextButton")
btn.Size = UDim2.new(1,-20,0,40)
btn.Position = UDim2.new(0,10,0,30)
btn.Text = "CARRY"
btn.Parent = frame

-- เปิด/ปิดเมนู
icon.MouseButton1Click:Connect(function()
	frame.Visible = not frame.Visible
end)

-- ===== ระบบอุ้ม (Local อย่างเดียว) =====
local carrying = false
local weld

btn.MouseButton1Click:Connect(function()
	local char = player.Character
	if not char then return end
	
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	
	-- ปล่อย
	if carrying and weld then
		weld:Destroy()
		weld = nil
		carrying = false
		btn.Text = "CARRY"
		return
	end
	
	-- หาเป้าหมาย
	local closest
	local dist = 10
	
	for _,p in pairs(game.Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local target = p.Character.HumanoidRootPart
			local d = (target.Position - root.Position).Magnitude
			
			if d < dist then
				dist = d
				closest = target
			end
		end
	end
	
	-- อุ้ม
	if closest then
		weld = Instance.new("WeldConstraint")
		weld.Part0 = root
		weld.Part1 = closest
		weld.Parent = root
		
		closest.CFrame = root.CFrame * CFrame.new(0,0,-2)
		
		carrying = true
		btn.Text = "DROP"
	end
end)
