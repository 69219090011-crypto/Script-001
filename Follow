local player = game.Players.LocalPlayer
local Players = game:GetService("Players")

-- ===== GUI =====
local gui = Instance.new("ScreenGui")
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,250,0,200)
frame.Position = UDim2.new(0,20,0,200)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Parent = gui
frame.Active = true
frame.Draggable = true

-- ปุ่มเปิด/ปิด
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(1,-20,0,30)
toggleBtn.Position = UDim2.new(0,10,0,10)
toggleBtn.Text = "FOLLOW: OFF"
toggleBtn.Parent = frame

-- รายชื่อผู้เล่น
local listFrame = Instance.new("ScrollingFrame")
listFrame.Size = UDim2.new(1,-20,0,140)
listFrame.Position = UDim2.new(0,10,0,50)
listFrame.CanvasSize = UDim2.new(0,0,0,0)
listFrame.BackgroundColor3 = Color3.fromRGB(50,50,50)
listFrame.Parent = frame

local selectedTarget = nil
local following = false

-- ===== สร้างรายชื่อ =====
local function updateList()
	listFrame:ClearAllChildren()
	local y = 0
	
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= player then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,0,0,30)
			btn.Position = UDim2.new(0,0,0,y)
			btn.Text = plr.Name
			btn.Parent = listFrame
			
			y = y + 30
			
			btn.MouseButton1Click:Connect(function()
				selectedTarget = plr
			end)
		end
	end
	
	listFrame.CanvasSize = UDim2.new(0,0,0,y)
end

updateList()
Players.PlayerAdded:Connect(updateList)
Players.PlayerRemoving:Connect(updateList)

-- ===== ปุ่ม =====
toggleBtn.MouseButton1Click:Connect(function()
	if selectedTarget then
		following = not following
		toggleBtn.Text = following and "FOLLOW: ON" or "FOLLOW: OFF"
	end
end)

-- ===== ติดตาม =====
local function follow()
	if selectedTarget and selectedTarget.Character and selectedTarget.Character:FindFirstChild("HumanoidRootPart") then
		local myChar = player.Character
		if myChar and myChar:FindFirstChild("HumanoidRootPart") then
			myChar.HumanoidRootPart.CFrame =
				selectedTarget.Character.HumanoidRootPart.CFrame * CFrame.new(3,0,3)
		end
	end
end

game:GetService("RunService").RenderStepped:Connect(function()
	if following then
		follow()
	end
end)

-- กันรีตอนตาย
player.CharacterAdded:Connect(function()
	task.wait(1)
end)
